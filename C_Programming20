#include <stdio.h>
int main()
{
    int i, j, count, total = 0;
    for(i = 1; i <= 9; i++)
    {
        count = 0;
        for(j = 1; j <= i; j++)
        {
            if(i % j == 0)
                count++;
        }
        if(count == 2)
        {
            printf("%d ", i);
            total++;
        }
    }
    printf("\nTotal Prime Numbers = %d", total);
    return 0;
}
