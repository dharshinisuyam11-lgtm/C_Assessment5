#include <stdio.h>
int main()
{
    int n, ones, tens;
    int i, count;
    printf("Enter a number: ");
    scanf("%d", &n);
    ones = n % 10;
    tens = (n / 10) % 10;
    count = 0;
    for(i = 1; i <= ones; i++)
    {
        if(ones % i == 0)
            count++;
    }
    if(count == 2)
        printf("Ones digit is Prime\n");
    else
        printf("Ones digit is Not Prime\n");
    count = 0;
    for(i = 1; i <= tens; i++)
    {
        if(tens % i == 0)
            count++;
    }
    if(count == 2)
        printf("Tens digit is Prime\n");
    else
        printf("Tens digit is Not Prime\n");

    return 0;
}
