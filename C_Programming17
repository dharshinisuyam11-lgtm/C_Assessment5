#include <stdio.h>
int main()
{
    int n, i, count = 0, sum = 0, temp;
    printf("Enter a number: ");
    scanf("%d", &n);
    temp = n;
    while (temp > 0)
    {
        sum = sum + (temp % 10);
        temp = temp / 10;
    }
    for (i = 1; i <= n; i++)
    {
        if (n % i == 0)
            count++;
    }
    if (count == 2 && sum == 14)
        printf("Prime and sum of digits is 14");
    else
        printf("Condition not satisfied");
    return 0;
}
