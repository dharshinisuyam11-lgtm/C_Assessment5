#include <stdio.h>
int main()
{
    int n, d, i, count;
    printf("Enter a number: ");
    scanf("%d", &n);
    d = (n / 100) % 10;   // Hundreds digit
    count = 0;
    for(i = 1; i <= d; i++)
        if(d % i == 0)
            count++;
    if(count == 2)
        printf("Hundreds digit is Prime\n");
    else
        printf("Hundreds digit is Not Prime\n");
    d = (n / 10) % 10;    // Tens digit
    count = 0;
    for(i = 1; i <= d; i++)
        if(d % i == 0)
            count++;
    if(count == 2)
        printf("Tens digit is Prime\n");
    else
        printf("Tens digit is Not Prime\n");

    return 0;
}
